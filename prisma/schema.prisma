generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String?
  role           String          @default("leader")
  accessRequests AccessRequest[]
  ownedEvents    ClubEvent[]     @relation("EventOwner")
  memberships    ClubMember[]
}

model Club {
  id              String          @id @default(uuid())
  airtableId      String?         @unique
  name            String
  description     String?
  contactName     String?
  contactEmail    String?
  calendarUrl     String?
  discordUrl      String?
  websiteUrl      String?
  instagramUrl    String?
  linkedinUrl     String?
  reviewNotes     String?
  reviewedAt      DateTime?       @default(now())
  status          Status          @default(pending)
  submittedAt     DateTime?       @default(now())
  communityStatus ClubStatus      @default(unofficial)
  communityType   CommType        @default(Other)
  updatedAt       DateTime?       @default(now())
  accessRequests  AccessRequest[]
  events          ClubEvent[]
  members         ClubMember[]
}

model ClubMember {
  id         Int        @id @default(autoincrement())
  userId     String
  clubId     String
  name       String
  memberRole MemberRole @default(leader)
  createdAt  DateTime   @default(now())
  club       Club       @relation(fields: [clubId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@unique([userId, clubId])
}

model AccessRequest {
  id              String    @id @default(uuid())
  requesterUserId String
  clubId          String
  club            Club     @relation(fields: [clubId], references: [id]) 
  requesterEmail  String
  message         String
  reviewNotes     String?
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime? @updatedAt
  status          Status    @default(pending)
  user            User      @relation(fields: [requesterUserId], references: [id])
}

model ClubEvent {
  id               String   @id @default(uuid())
  clubId           String
  ownerUserId      String
  name             String
  eventTitle       String
  eventDate        DateTime
  eventLocation    String
  eventDescription String
  iceBreakers      String
  channelId        String?
  createdAt        DateTime @default(now())
  zoomLink         String?
  club             Club     @relation(fields: [clubId], references: [id])
  owner            User     @relation("EventOwner", fields: [ownerUserId], references: [id])
}

enum ClubStatus {
  verified
  unofficial
}

enum CommType {
  Campus_Department_Program
  Professional_and_Career
  Performing_and_Visual_Arts
  Cultural_and_Identity
  Greek_letter
  Academic
  Sports_and_Recreation
  Media_and_Broadcasting
  Politics_and_Advocacy
  Research
  Other
}

enum Status {
  pending
  approved
  rejected
}

enum MemberRole {
  admin
  leader
}
